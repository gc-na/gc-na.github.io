<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<svg width="180" height="180" viewBox="0 0 180 180" xmlns="http://www.w3.org/2000/svg">
  <!-- 배경 원 -->
  <circle cx="90" cy="90" r="85" fill="#0e76a8" />
  <circle cx="90" cy="90" r="75" fill="#ffffff" />
  
  <!-- 가운데 반도체 칩 아이콘 -->
  <rect x="45" y="45" width="90" height="90" rx="5" fill="#0e76a8" />
  
  <!-- 칩의 선들 -->
  <line x1="45" y1="55" x2="35" y2="55" stroke="#0e76a8" stroke-width="3" />
  <line x1="45" y1="70" x2="35" y2="70" stroke="#0e76a8" stroke-width="3" />
  <line x1="45" y1="85" x2="35" y2="85" stroke="#0e76a8" stroke-width="3" />
  <line x1="45" y1="100" x2="35" y2="100" stroke="#0e76a8" stroke-width="3" />
  <line x1="45" y1="115" x2="35" y2="115" stroke="#0e76a8" stroke-width="3" />
  
  <line x1="135" y1="55" x2="145" y2="55" stroke="#0e76a8" stroke-width="3" />
  <line x1="135" y1="70" x2="145" y2="70" stroke="#0e76a8" stroke-width="3" />
  <line x1="135" y1="85" x2="145" y2="85" stroke="#0e76a8" stroke-width="3" />
  <line x1="135" y1="100" x2="145" y2="100" stroke="#0e76a8" stroke-width="3" />
  <line x1="135" y1="115" x2="145" y2="115" stroke="#0e76a8" stroke-width="3" />
  
  <line x1="55" y1="45" x2="55" y2="35" stroke="#0e76a8" stroke-width="3" />
  <line x1="70" y1="45" x2="70" y2="35" stroke="#0e76a8" stroke-width="3" />
  <line x1="85" y1="45" x2="85" y2="35" stroke="#0e76a8" stroke-width="3" />
  <line x1="100" y1="45" x2="100" y2="35" stroke="#0e76a8" stroke-width="3" />
  <line x1="115" y1="45" x2="115" y2="35" stroke="#0e76a8" stroke-width="3" />
  
  <line x1="55" y1="135" x2="55" y2="145" stroke="#0e76a8" stroke-width="3" />
  <line x1="70" y1="135" x2="70" y2="145" stroke="#0e76a8" stroke-width="3" />
  <line x1="85" y1="135" x2="85" y2="145" stroke="#0e76a8" stroke-width="3" />
  <line x1="100" y1="135" x2="100" y2="145" stroke="#0e76a8" stroke-width="3" />
  <line x1="115" y1="135" x2="115" y2="145" stroke="#0e76a8" stroke-width="3" />
  
  <!-- 내부 패턴 -->
  <rect x="55" y="55" width="20" height="20" fill="#ffffff" />
  <rect x="85" y="55" width="20" height="20" fill="#ffffff" />
  <rect x="115" y="55" width="20" height="20" fill="#ffffff" />
  
  <rect x="55" y="85" width="20" height="20" fill="#ffffff" />
  <rect x="85" y="85" width="20" height="20" fill="#ffffff" />
  <rect x="115" y="85" width="20" height="20" fill="#ffffff" />
  
  <rect x="55" y="115" width="20" height="20" fill="#ffffff" />
  <rect x="85" y="115" width="20" height="20" fill="#ffffff" />
  <rect x="115" y="115" width="20" height="20" fill="#ffffff" />
</svg>
