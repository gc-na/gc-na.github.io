  <line x1="22" y1="8" x2="22" y2="6" stroke="#0e76a8" stroke-width="1" />
  
  <line x1="10" y1="24" x2="10" y2="26" stroke="#0e76a8" stroke-width="1" />
  <line x1="13" y1="24" x2="13" y2="26" stroke="#0e76a8" stroke-width="1" />
