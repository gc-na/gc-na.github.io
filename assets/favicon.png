  <line x1="24" y1="19" x2="26" y2="19" stroke="#0e76a8" stroke-width="1" />
  
  <line x1="10" y1="8" x2="10" y2="6" stroke="#0e76a8" stroke-width="1" />
  <line x1="13" y1="8" x2="13" y2="6" stroke="#0e76a8" stroke-width="1" />
